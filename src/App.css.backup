* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  scroll-behavior: smooth;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
  line-height: 1.6;
  color: #333;
  overflow-x: hidden;
}

.app {
  min-height: 100vh;
  position: relative;
}

/* Animated Background Circles */
.bg-circles {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: -1;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  animation: float 20s infinite ease-in-out;
}

.circle-1 {
  width: 300px;
  height: 300px;
  top: 10%;
  left: 10%;
  animation-delay: 0s;
}

.circle-2 {
  width: 200px;
  height: 200px;
  top: 60%;
  right: 10%;
  animation-delay: 5s;
}

.circle-3 {
  width: 250px;
  height: 250px;
  bottom: 10%;
  left: 50%;
  animation-delay: 10s;
}

@keyframes float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30px, -30px) scale(1.1); }
  66% { transform: translate(-20px, 20px) scale(0.9); }
}

/* Navbar */
.navbar {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  padding: 1rem 2rem;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  font-size: 2rem;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.nav-links {
  display: flex;
  gap: 2rem;
}

.nav-links a {
  text-decoration: none;
  color: #333;
  font-weight: 600;
  position: relative;
  transition: color 0.3s;
}

.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -5px;
  left: 0;
  width: 0;
  height: 2px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  transition: width 0.3s;
}

.nav-links a:hover::after {
  width: 100%;
}

.nav-links a:hover {
  color: #667eea;
}

/* Hero Section */
.hero {
  min-height: 90vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 4rem;
  padding: 4rem 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.hero-content h1 {
  font-size: 3.5rem;
  margin-bottom: 1rem;
  line-height: 1.2;
}

.gradient-text {
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-content h2 {
  font-size: 1.5rem;
  color: #666;
  margin-bottom: 1rem;
}

.hero-content p {
  font-size: 1.2rem;
  color: #777;
  margin-bottom: 2rem;
}

.hero-buttons {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
}

.btn-primary, .btn-secondary {
  padding: 1rem 2rem;
  text-decoration: none;
  border-radius: 50px;
  font-weight: 600;
  transition: all 0.3s;
  display: inline-block;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
}

.btn-secondary {
  background: transparent;
  color: #667eea;
  border: 2px solid #667eea;
}

.social-links {
  display: flex;
  gap: 1.5rem;
}

.social-links a {
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f9fa;
  border-radius: 50%;
  color: #667eea;
  transition: all 0.3s;
}

.social-links a:hover {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}

/* Hero Image */
.hero-image {
  display: flex;
  justify-content: center;
  align-items: center;
}

.profile-circle {
  width: 350px;
  height: 350px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 10px;
  box-shadow: 0 20px 60px rgba(102, 126, 234, 0.4);
}

.profile-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #764ba2, #667eea);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 5rem;
  font-weight: bold;
  color: white;
}

/* Sections */
.section {
  padding: 5rem 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.section h2 {
  font-size: 3rem;
  text-align: center;
  margin-bottom: 3rem;
}

/* About Section */
.about-content {
  max-width: 800px;
  margin: 0 auto;
  text-align: center;
}

.about-content p {
  font-size: 1.2rem;
  line-height: 1.8;
  margin-bottom: 1.5rem;
  color: #555;
}

/* Skills Section */
.skills-section {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
}

.skill-card {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  text-align: center;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.skill-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 5px;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.skill-icon {
  color: #667eea;
  margin-bottom: 1rem;
}

.skill-card h3 {
  color: #333;
  margin-bottom: 1rem;
  font-size: 1.5rem;
}

.skill-card p {
  color: #666;
  font-size: 1.1rem;
}

/* Projects Section */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
}

.project-card {
  background: white;
  padding: 2rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.project-number {
  position: absolute;
  top: 20px;
  right: 20px;
  font-size: 3rem;
  font-weight: bold;
  color: rgba(102, 126, 234, 0.1);
}

.project-card h3 {
  color: #333;
  margin-bottom: 1rem;
  font-size: 1.5rem;
}

.project-card p {
  color: #666;
  margin-bottom: 1rem;
  line-height: 1.6;
}

.project-tech {
  display: inline-block;
  padding: 0.5rem 1rem;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 20px;
  font-size: 0.9rem;
  color: #667eea;
  margin-bottom: 1rem;
}

.project-card a {
  color: #667eea;
  text-decoration: none;
  font-weight: 600;
  display: inline-block;
  margin-top: 1rem;
}

/* Contact Section */
.contact-section {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
}

.contact-info {
  max-width: 600px;
  margin: 0 auto;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.5rem;
  background: white;
  border-radius: 15px;
  margin-bottom: 1rem;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  transition: all 0.3s;
}

.contact-item svg {
  color: #667eea;
  flex-shrink: 0;
}

.contact-item span,
.contact-item a {
  color: #333;
  text-decoration: none;
  font-size: 1.1rem;
}

.contact-item a:hover {
  color: #667eea;
}

/* Footer */
footer {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  text-align: center;
  padding: 2rem;
  font-size: 1.1rem;
}

/* Responsive */
@media (max-width: 768px) {
  .hero {
    grid-template-columns: 1fr;
    text-align: center;
  }
  
  .hero-content h1 {
    font-size: 2.5rem;
  }
  
  .profile-circle {
    width: 250px;
    height: 250px;
  }
  
  .nav-links {
    gap: 1rem;
    font-size: 0.9rem;
  }
  
  .section h2 {
    font-size: 2rem;
  }
}

/* About Section Expanded */
.about-section {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.03), rgba(118, 75, 162, 0.03));
}

.about-container {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 3rem;
  align-items: start;
}

.about-text {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}

.intro-text {
  font-size: 1.3rem;
  font-weight: 500;
  margin-bottom: 1.5rem;
  color: #333;
}

.about-text p {
  font-size: 1.1rem;
  line-height: 1.8;
  margin-bottom: 1.5rem;
  color: #555;
}

.about-stats {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
}

.stat-card {
  background: white;
  padding: 2rem;
  border-radius: 15px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  text-align: center;
  border-left: 5px solid;
  border-image: linear-gradient(135deg, #667eea, #764ba2) 1;
}

.stat-number {
  font-size: 3rem;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 0.5rem;
}

.stat-label {
  font-size: 1rem;
  color: #666;
  font-weight: 500;
}

/* Skills Tags */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
  margin-top: 1rem;
}

.skill-tags span {
  padding: 0.5rem 1rem;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 20px;
  font-size: 0.9rem;
  color: #667eea;
  font-weight: 500;
}

/* Project Date */
.project-date {
  position: absolute;
  top: 20px;
  left: 20px;
  padding: 0.5rem 1rem;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 600;
}

/* Experience Section */
.experience-section {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.03), rgba(118, 75, 162, 0.03));
}

.timeline {
  max-width: 900px;
  margin: 0 auto;
  position: relative;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 30px;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.timeline-item {
  display: flex;
  gap: 2rem;
  margin-bottom: 3rem;
  position: relative;
}

.timeline-icon {
  width: 60px;
  height: 60px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  flex-shrink: 0;
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
  z-index: 1;
}

.timeline-content {
  background: white;
  padding: 2rem;
  border-radius: 15px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  flex: 1;
}

.timeline-content h3 {
  font-size: 1.5rem;
  color: #333;
  margin-bottom: 0.5rem;
}

.timeline-content h4 {
  color: #667eea;
  margin-bottom: 0.5rem;
}

.timeline-date {
  color: #999;
  font-size: 0.9rem;
  margin-bottom: 1rem;
}

.timeline-content ul {
  list-style: none;
  padding: 0;
}

.timeline-content li {
  padding-left: 1.5rem;
  margin-bottom: 0.5rem;
  position: relative;
  color: #555;
}

.timeline-content li::before {
  content: '▹';
  position: absolute;
  left: 0;
  color: #667eea;
  font-weight: bold;
}

/* Education Section */
.education-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
  margin-bottom: 4rem;
}

.education-card {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  text-align: center;
  transition: all 0.3s;
}

.edu-icon {
  color: #667eea;
  margin-bottom: 1rem;
}

.education-card h3 {
  font-size: 1.5rem;
  color: #333;
  margin-bottom: 0.5rem;
}

.education-card h4 {
  color: #667eea;
  margin-bottom: 1rem;
  font-size: 1.1rem;
}

.edu-institution {
  color: #666;
  margin-bottom: 0.5rem;
}

.edu-date {
  color: #999;
  font-size: 0.9rem;
  margin-bottom: 0.5rem;
}

.edu-grade {
  font-weight: bold;
  color: #667eea;
  font-size: 1.1rem;
  margin: 1rem 0;
}

.edu-subjects {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
  margin-top: 1rem;
}

.edu-subjects span {
  padding: 0.4rem 0.8rem;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 15px;
  font-size: 0.85rem;
  color: #667eea;
}

/* Certifications */
.certifications {
  margin-top: 4rem;
}

.cert-title {
  text-align: center;
  font-size: 2rem;
  margin-bottom: 2rem;
  color: #333;
}

.cert-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
}

.cert-card {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  padding: 2rem;
  border-radius: 15px;
  text-align: center;
  transition: all 0.3s;
}

.cert-icon {
  color: #667eea;
  margin-bottom: 1rem;
}

.cert-card h4 {
  color: #333;
  margin-bottom: 0.5rem;
  font-size: 1.1rem;
}

.cert-card p {
  color: #666;
  margin-bottom: 0.5rem;
}

.cert-date {
  display: inline-block;
  padding: 0.3rem 0.8rem;
  background: white;
  border-radius: 15px;
  font-size: 0.85rem;
  color: #667eea;
  font-weight: 600;
}

/* Achievements Section */
.achievements-section {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.03), rgba(118, 75, 162, 0.03));
}

.achievements-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
}

.achievement-card {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  text-align: center;
  transition: all 0.3s;
}

.achievement-icon {
  font-size: 4rem;
  margin-bottom: 1rem;
}

.achievement-card h3 {
  color: #333;
  margin-bottom: 1rem;
  font-size: 1.3rem;
}

.achievement-card p {
  color: #666;
  margin-bottom: 1rem;
  line-height: 1.6;
}

.achievement-date {
  display: inline-block;
  padding: 0.5rem 1rem;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 20px;
  font-size: 0.9rem;
  color: #667eea;
  font-weight: 600;
}

/* Contact Subtitle */
.contact-subtitle {
  text-align: center;
  font-size: 1.2rem;
  color: #666;
  max-width: 700px;
  margin: 0 auto 3rem;
}

/* Responsive Updates */
@media (max-width: 768px) {
  .about-container {
    grid-template-columns: 1fr;
  }
  
  .nav-links {
    display: none;
  }
  
  .timeline::before {
    left: 15px;
  }
  
  .timeline-icon {
    width: 40px;
    height: 40px;
  }
  
  .timeline-item {
    gap: 1rem;
  }
}

/* Page Layout */
.page {
  min-height: calc(100vh - 80px);
  padding-top: 80px;
}

.page-title {
  font-size: 3.5rem;
  text-align: center;
  margin-bottom: 1rem;
}

.page-subtitle {
  text-align: center;
  font-size: 1.2rem;
  color: #666;
  max-width: 800px;
  margin: 0 auto 3rem;
}

/* Active Nav Link */
.nav-links a.active {
  color: #667eea;
  font-weight: 700;
}

.nav-links a.active::after {
  width: 100%;
}

/* Quick Stats on Home */
.quick-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 2rem;
  max-width: 1200px;
  margin: -50px auto 0;
  padding: 0 2rem;
  position: relative;
  z-index: 10;
}

.stat-box {
  background: white;
  padding: 2rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  text-align: center;
  transition: all 0.3s;
}

/* Projects Page */
.projects-page {
  padding: 2rem;
}

.projects-grid-page {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2.5rem;
  max-width: 1200px;
  margin: 0 auto;
}

.project-card-large {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  transition: all 0.3s;
  position: relative;
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.project-tech-list {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 1.5rem 0;
}

.tech-tag {
  padding: 0.5rem 1rem;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 20px;
  font-size: 0.85rem;
  color: #667eea;
  font-weight: 500;
}

.project-links {
  margin-top: 1.5rem;
}

.project-link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: #667eea;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s;
}

/* Skills Page */
.skills-page .skill-card {
  min-height: 350px;
}

.skill-desc {
  margin-top: 1rem;
  color: #666;
  line-height: 1.6;
}

.competencies {
  margin-top: 4rem;
  text-align: center;
}

.competencies h2 {
  font-size: 2.5rem;
  margin-bottom: 2rem;
  color: #333;
}

.competency-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.competency-item {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  padding: 2rem;
  border-radius: 15px;
  transition: all 0.3s;
}

.competency-item h4 {
  color: #333;
  margin-bottom: 0.5rem;
  font-size: 1.2rem;
}

.competency-item p {
  color: #666;
  line-height: 1.6;
}

/* About Page */
.about-page .about-container {
  max-width: 1200px;
  margin: 0 auto;
}

.interests {
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 2px solid #f0f0f0;
}

.interests h3 {
  font-size: 1.5rem;
  margin-bottom: 1rem;
  color: #333;
}

.interest-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

.interest-tags span {
  padding: 0.7rem 1.2rem;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 25px;
  font-size: 1rem;
  color: #667eea;
  font-weight: 500;
}

/* Contact Page */
.contact-page {
  max-width: 1000px;
  margin: 0 auto;
}

.contact-container {
  max-width: 900px;
  margin: 0 auto;
}

.contact-info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  margin-bottom: 4rem;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 2rem;
  background: white;
  border-radius: 15px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  transition: all 0.3s;
}

.contact-item svg {
  color: #667eea;
  flex-shrink: 0;
}

.contact-item h4 {
  font-size: 0.9rem;
  color: #999;
  margin-bottom: 0.3rem;
}

.contact-item a,
.contact-item span {
  color: #333;
  text-decoration: none;
  font-size: 1.1rem;
  font-weight: 500;
}

.contact-item a:hover {
  color: #667eea;
}

.social-section {
  text-align: center;
}

.social-section h3 {
  font-size: 2rem;
  margin-bottom: 2rem;
  color: #333;
}

.social-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 2rem;
}

.social-card {
  background: white;
  padding: 2.5rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  text-align: center;
  text-decoration: none;
  color: #333;
  transition: all 0.3s;
}

.social-card svg {
  color: #667eea;
  margin-bottom: 1rem;
}

.social-card h4 {
  font-size: 1.3rem;
  margin-bottom: 0.5rem;
}

.social-card p {
  color: #666;
  font-size: 0.9rem;
}

/* Education Page */
.education-page .education-grid {
  max-width: 1200px;
  margin: 0 auto 4rem;
}

/* Button Styles */
.btn-primary,
.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border: none;
  cursor: pointer;
  font-family: inherit;
}

/* Responsive for Multi-page */
@media (max-width: 768px) {
  .page-title {
    font-size: 2.5rem;
  }
  
  .projects-grid-page {
    grid-template-columns: 1fr;
  }
  
  .quick-stats {
    grid-template-columns: repeat(2, 1fr);
    margin-top: 2rem;
  }
}

/* Skills Icon Grid */
.skill-category-section {
  margin-bottom: 4rem;
}

.category-title {
  font-size: 2rem;
  color: #333;
  margin-bottom: 2rem;
  text-align: center;
  position: relative;
  padding-bottom: 1rem;
}

.category-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100px;
  height: 3px;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.skills-icon-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 2rem;
  max-width: 1000px;
  margin: 0 auto;
}

.skill-icon-card {
  background: white;
  padding: 2rem;
  border-radius: 20px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  text-align: center;
  transition: all 0.3s;
  border: 2px solid transparent;
}

.skill-icon-card:hover {
  border-color: rgba(102, 126, 234, 0.3);
}

.skill-icon-wrapper {
  width: 80px;
  height: 80px;
  margin: 0 auto 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 15px;
  transition: all 0.3s;
}

.skill-icon-card:hover .skill-icon-wrapper {
  background: rgba(102, 126, 234, 0.1);
  transform: rotate(5deg) scale(1.1);
}

.skill-icon-img {
  width: 50px;
  height: 50px;
  object-fit: contain;
}

.skill-icon-card h4 {
  font-size: 1.1rem;
  color: #333;
  font-weight: 600;
}

/* Competencies */
.competencies {
  margin-top: 5rem;
  text-align: center;
}

.competencies h2 {
  font-size: 2.5rem;
  margin-bottom: 2rem;
  color: #333;
}

.competency-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
  max-width: 1200px;
  margin: 0 auto;
}

.competency-item {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  padding: 2rem;
  border-radius: 15px;
  transition: all 0.3s;
}

.competency-item h4 {
  color: #333;
  margin-bottom: 0.5rem;
  font-size: 1.2rem;
}

.competency-item p {
  color: #666;
  line-height: 1.6;
}

/* Advanced Graphics Effects */

/* Animated Gradient Background - Creative & Subtle */
.page {
  position: relative;
  background: linear-gradient(135deg, 
    #e0c3fc 0%,
    #8ec5fc 25%, 
    #fbc2eb 50%, 
    #a6c1ee 75%, 
    #e0c3fc 100%
  );
  animation: gradientBG 15s ease infinite;
  background-size: 400% 400%;
}

@keyframes gradientBG {
  0% { background-position: 0% 50%; }
  25% { background-position: 50% 100%; }
  50% { background-position: 100% 50%; }
  75% { background-position: 50% 0%; }
  100% { background-position: 0% 50%; }
}

/* Glassmorphism Effect - Enhanced */
.skill-icon-card {
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow: 
    0 8px 32px 0 rgba(102, 126, 234, 0.2),
    inset 0 1px 0 0 rgba(255, 255, 255, 0.5);
  position: relative;
  overflow: hidden;
}

/* Shimmer Effect on Hover */
.skill-icon-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent,
    rgba(255, 255, 255, 0.5),
    transparent
  );
  transform: rotate(45deg);
  transition: all 0.6s;
  opacity: 0;
}

.skill-icon-card:hover::before {
  animation: shimmer 1.5s infinite;
  opacity: 1;
}

@keyframes shimmer {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}

/* Card Hover Effect - Simple Scale */
.skill-icon-card {
  transition: all 0.4s ease;
}

.skill-icon-card:hover {
  transform: translateY(-10px) scale(1.05);
}

/* Floating Animation - Enhanced */
.skill-icon-wrapper {
  animation: float 3s ease-in-out infinite;
}

.skill-icon-card:nth-child(1) .skill-icon-wrapper { animation-delay: 0s; }
.skill-icon-card:nth-child(2) .skill-icon-wrapper { animation-delay: 0.2s; }
.skill-icon-card:nth-child(3) .skill-icon-wrapper { animation-delay: 0.4s; }
.skill-icon-card:nth-child(4) .skill-icon-wrapper { animation-delay: 0.6s; }

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  25% { transform: translateY(-15px) rotate(2deg); }
  50% { transform: translateY(-20px) rotate(0deg); }
  75% { transform: translateY(-15px) rotate(-2deg); }
}

/* Glow Effect */
.skill-icon-card::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.4), transparent);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
  z-index: -1;
}

.skill-icon-card:hover::after {
  width: 300px;
  height: 300px;
}

/* Neon Glow Effect - Enhanced */
.skill-icon-card:hover {
  border-color: rgba(102, 126, 234, 0.8);
  box-shadow: 
    0 0 10px rgba(102, 126, 234, 0.8),
    0 0 20px rgba(102, 126, 234, 0.6),
    0 0 40px rgba(102, 126, 234, 0.4),
    0 0 80px rgba(102, 126, 234, 0.2),
    inset 0 0 20px rgba(102, 126, 234, 0.2);
  animation: neonPulse 1.5s ease-in-out infinite;
}

@keyframes neonPulse {
  0%, 100% {
    box-shadow: 
      0 0 10px rgba(102, 126, 234, 0.8),
      0 0 20px rgba(102, 126, 234, 0.6),
      0 0 40px rgba(102, 126, 234, 0.4);
  }
  50% {
    box-shadow: 
      0 0 20px rgba(102, 126, 234, 1),
      0 0 40px rgba(102, 126, 234, 0.8),
      0 0 80px rgba(102, 126, 234, 0.6);
  }
}

/* Particle Effect Background */
.skills-page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    radial-gradient(circle at 20% 50%, rgba(102, 126, 234, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(118, 75, 162, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 20%, rgba(240, 147, 251, 0.1) 0%, transparent 50%);
  animation: particleMove 20s ease-in-out infinite;
  z-index: 0;
}

@keyframes particleMove {
  0%, 100% { transform: translate(0, 0); }
  33% { transform: translate(50px, -50px); }
  66% { transform: translate(-50px, 50px); }
}

.skills-page > * {
  position: relative;
  z-index: 1;
}

/* Rainbow Border Animation */
.category-title::before {
  content: '';
  position: absolute;
  top: -5px;
  left: -5px;
  right: -5px;
  bottom: -5px;
  background: linear-gradient(45deg, #667eea, #764ba2, #f093fb, #667eea);
  background-size: 400%;
  border-radius: 10px;
  opacity: 0;
  z-index: -1;
  animation: rainbowBorder 3s linear infinite;
  transition: opacity 0.3s;
}

@keyframes rainbowBorder {
  0% { background-position: 0% 50%; }
  100% { background-position: 400% 50%; }
}

/* Pulse Effect on Icons */
.skill-icon-img {
  animation: iconPulse 2s ease-in-out infinite;
}

@keyframes iconPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.skill-icon-card:hover .skill-icon-img {
  animation: iconSpin 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes iconSpin {
  0% { transform: rotate(0deg) scale(1); }
  25% { transform: rotate(90deg) scale(1.1); }
  50% { transform: rotate(180deg) scale(1.3); }
  75% { transform: rotate(270deg) scale(1.1); }
  100% { transform: rotate(360deg) scale(1); }
}

/* Competency Cards with Gradient Border */
.competency-item {
  position: relative;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  border: 2px solid transparent;
  background-clip: padding-box;
}

.competency-item::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 15px;
  padding: 2px;
  background: linear-gradient(135deg, #667eea, #764ba2, #f093fb);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 0.3s;
}

.competency-item:hover::before {
  opacity: 1;
}

/* Floating Shapes Background */
.section::after {
  content: '';
  position: absolute;
  width: 300px;
  height: 300px;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 50%;
  top: 10%;
  right: 5%;
  animation: floatShape 15s ease-in-out infinite;
  z-index: 0;
}

@keyframes floatShape {
  0%, 100% { transform: translate(0, 0) rotate(0deg); }
  33% { transform: translate(50px, -50px) rotate(120deg); }
  66% { transform: translate(-50px, 50px) rotate(240deg); }
}

/* Text Gradient Animation */
.page-title {
  background: linear-gradient(135deg, #667eea, #764ba2, #f093fb, #667eea);
  background-size: 300%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: textGradient 5s ease infinite;
}

@keyframes textGradient {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

/* Hover Lift Effect */
.competency-item {
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.competency-item:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 
    0 20px 40px rgba(102, 126, 234, 0.3),
    0 10px 20px rgba(118, 75, 162, 0.2);
}

/* Sparkle Effect - Enhanced */
@keyframes sparkle {
  0%, 100% { 
    opacity: 0; 
    transform: scale(0) rotate(0deg); 
  }
  50% { 
    opacity: 1; 
    transform: scale(1.2) rotate(180deg); 
  }
}

.skill-icon-card:hover .skill-icon-wrapper::after {
  content: '✨';
  position: absolute;
  top: -15px;
  right: -15px;
  font-size: 2rem;
  animation: sparkle 1s ease-in-out infinite;
  filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.8));
}

.skill-icon-card:hover .skill-icon-wrapper::before {
  content: '⭐';
  position: absolute;
  bottom: -15px;
  left: -15px;
  font-size: 1.5rem;
  animation: sparkle 1s ease-in-out infinite 0.5s;
  filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.8));
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .skill-icon-card:hover {
    transform: perspective(1000px) translateZ(10px);
  }
}

/* Creative Competencies Section */
.competencies-title {
  font-size: 3rem;
  text-align: center;
  margin-bottom: 3rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
}

.title-icon {
  font-size: 2.5rem;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.competency-grid-creative {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2.5rem;
  max-width: 1200px;
  margin: 0 auto 5rem;
}

.competency-card-creative {
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(20px);
  padding: 2.5rem;
  border-radius: 25px;
  text-align: center;
  position: relative;
  overflow: hidden;
  border: 2px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.competency-card-creative::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 5px;
  background: var(--card-color);
  box-shadow: 0 0 20px var(--card-color);
}

.competency-icon-circle {
  width: 100px;
  height: 100px;
  margin: 0 auto 1.5rem;
  background: linear-gradient(135deg, var(--card-color), rgba(255, 255, 255, 0.3));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.competency-emoji {
  font-size: 3rem;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.competency-title-text {
  font-size: 1.4rem;
  color: #333;
  margin-bottom: 1rem;
  font-weight: 700;
}

.competency-desc-text {
  color: #555;
  line-height: 1.6;
  font-size: 1rem;
}

.competency-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}

.competency-card-creative:hover {
  box-shadow: 
    0 20px 50px rgba(0, 0, 0, 0.2),
    0 0 30px var(--card-color);
}

/* Soft Skills Section */
.soft-skills-section {
  margin-top: 5rem;
  padding: 3rem;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(15px);
  border-radius: 30px;
  border: 2px solid rgba(255, 255, 255, 0.4);
}

.soft-skills-title {
  font-size: 2.5rem;
  text-align: center;
  margin-bottom: 3rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  color: #333;
}

.soft-skills-grid {
  display: grid;
  gap: 1.5rem;
  max-width: 900px;
  margin: 0 auto;
}

.soft-skill-item {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10px);
  padding: 1.5rem;
  border-radius: 20px;
  border: 2px solid rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
}

.soft-skill-item:hover {
  background: rgba(255, 255, 255, 0.8);
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
}

.soft-skill-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.soft-skill-icon {
  font-size: 2rem;
  animation: wiggle 2s ease-in-out infinite;
}

@keyframes wiggle {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.soft-skill-name {
  flex: 1;
  font-size: 1.2rem;
  font-weight: 700;
  color: #333;
}

.soft-skill-percent {
  font-size: 1.1rem;
  font-weight: 700;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 0.3rem 0.8rem;
  border-radius: 15px;
}

.soft-skill-bar-bg {
  width: 100%;
  height: 12px;
  background: rgba(102, 126, 234, 0.2);
  border-radius: 10px;
  overflow: hidden;
  position: relative;
}

.soft-skill-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
  background-size: 200% 100%;
  border-radius: 10px;
  position: relative;
  animation: gradientMove 3s ease infinite;
}

@keyframes gradientMove {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.soft-skill-bar-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.5), transparent);
  animation: shimmerBar 2s infinite;
}

@keyframes shimmerBar {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* Responsive */
@media (max-width: 768px) {
  .competency-grid-creative {
    grid-template-columns: 1fr;
  }
  
  .competencies-title,
  .soft-skills-title {
    font-size: 2rem;
  }
}

/* Creative Home Page */
.home-page-creative {
  position: relative;
  overflow: hidden;
}

/* Floating Background Icons */
.floating-icons-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 0;
}

.floating-icon {
  position: absolute;
  color: rgba(102, 126, 234, 0.2);
  pointer-events: none;
}

/* Hero Creative */
.hero-creative {
  min-height: 90vh;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  align-items: center;
  gap: 4rem;
  padding: 4rem 2rem;
  max-width: 1400px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.hero-content-creative {
  z-index: 2;
}

.greeting-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.5rem;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-radius: 50px;
  font-size: 1.2rem;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 1.5rem;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
}

.wave {
  animation: wave 2s ease-in-out infinite;
  display: inline-block;
}

@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(20deg); }
  75% { transform: rotate(-20deg); }
}

.name-creative {
  font-size: 5rem;
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 1.5rem;
  color: #1a1a1a;
}

.gradient-text-animated {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientShift 4s ease infinite;
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.typing-wrapper {
  height: 90px;
  margin-bottom: 1.5rem;
}

.typing-text-creative {
  font-size: 2.8rem;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}

.hero-desc-creative {
  font-size: 1.3rem;
  line-height: 1.8;
  color: #555;
  margin-bottom: 2rem;
  max-width: 600px;
}

.highlight-text {
  color: #667eea;
  font-weight: 700;
  position: relative;
  padding: 0 0.2rem;
}

.highlight-text::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: linear-gradient(90deg, #667eea, #764ba2);
  opacity: 0.5;
}

.tags-container {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
}

.tag {
  padding: 0.6rem 1.2rem;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-radius: 25px;
  font-size: 1rem;
  font-weight: 600;
  color: #667eea;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  animation: tagFloat 3s ease-in-out infinite;
}

.tag:nth-child(1) { animation-delay: 0s; }
.tag:nth-child(2) { animation-delay: 0.5s; }
.tag:nth-child(3) { animation-delay: 1s; }

@keyframes tagFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

.hero-buttons-creative {
  display: flex;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
  flex-wrap: wrap;
}

.btn-gradient-creative {
  padding: 1.2rem 2.5rem;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border: none;
  border-radius: 50px;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
}

.btn-gradient-creative::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.5s;
}

.btn-gradient-creative:hover::before {
  left: 100%;
}

.btn-outline-creative {
  padding: 1.2rem 2.5rem;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  color: #667eea;
  border: 2px solid #667eea;
  border-radius: 50px;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
}

.btn-outline-creative:hover {
  background: #667eea;
  color: white;
}

.social-links-creative {
  display: flex;
  gap: 1rem;
}

.social-icon-creative {
  width: 55px;
  height: 55px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  color: #667eea;
  transition: all 0.3s;
  box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  border: 2px solid transparent;
}

.social-icon-creative:hover {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-color: white;
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
}

/* Floating Card Creative */
.hero-visual-creative {
  perspective: 1000px;
  z-index: 2;
}

.floating-card-creative {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  border-radius: 30px;
  padding: 3rem;
  box-shadow: 0 30px 80px rgba(102, 126, 234, 0.3);
  position: relative;
  border: 2px solid rgba(255, 255, 255, 0.5);
}

.card-glow-creative {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(102, 126, 234, 0.3), transparent 70%);
  animation: glowPulse 4s ease-in-out infinite;
  z-index: -1;
}

.profile-avatar-creative {
  width: 200px;
  height: 200px;
  margin: 0 auto 2rem;
  position: relative;
}

.avatar-ring-creative {
  position: absolute;
  inset: -10px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2, #f093fb);
  animation: rotate 3s linear infinite;
}

.avatar-content-creative {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #764ba2, #667eea);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 4rem;
  font-weight: bold;
  color: white;
  z-index: 1;
}

.card-info-creative {
  text-align: center;
}

.card-info-creative h3 {
  font-size: 1.8rem;
  color: #333;
  margin-bottom: 0.5rem;
}

.card-info-creative p {
  color: #667eea;
  font-size: 1.1rem;
  margin-bottom: 1rem;
}

.status-badge-creative {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.5rem;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 25px;
  font-size: 0.9rem;
  color: #667eea;
  font-weight: 600;
}

.status-dot-creative {
  width: 8px;
  height: 8px;
  background: #4ade80;
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

/* Stats Creative */
.stats-creative {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2rem;
  max-width: 1400px;
  margin: -50px auto 5rem;
  padding: 0 2rem;
  position: relative;
  z-index: 10;
}

.stat-card-creative {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  padding: 2.5rem;
  border-radius: 25px;
  text-align: center;
  box-shadow: 0 15px 40px rgba(0,0,0,0.1);
  border: 2px solid rgba(255, 255, 255, 0.5);
  transition: all 0.4s;
}

.stat-icon-creative {
  font-size: 3rem;
  margin-bottom: 1rem;
  animation: bounce 2s ease-in-out infinite;
}

.stat-number-creative {
  font-size: 3rem;
  font-weight: 900;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 0.5rem;
}

.stat-label-creative {
  font-size: 1rem;
  color: #666;
  font-weight: 600;
}

/* Responsive */
@media (max-width: 1024px) {
  .hero-creative {
    grid-template-columns: 1fr;
    text-align: center;
  }
  
  .name-creative {
    font-size: 3.5rem;
  }
  
  .typing-text-creative {
    font-size: 2rem;
  }
  
  .hero-desc-creative {
    margin: 0 auto 2rem;
  }
  
  .hero-buttons-creative {
    justify-content: center;
  }
  
  .social-links-creative {
    justify-content: center;
  }
  
  .tags-container {
    justify-content: center;
  }
}

@media (max-width: 768px) {
  .name-creative {
    font-size: 2.5rem;
  }
  
  .typing-text-creative {
    font-size: 1.5rem;
  }
  
  .stats-creative {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Achievement Card with Certificate */
.achievement-card-with-cert {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  padding: 1.5rem;
  border-radius: 20px;
  transition: all 0.3s;
  border: 2px solid transparent;
}

.achievement-card-with-cert:hover {
  border-color: rgba(102, 126, 234, 0.3);
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
}

.achievement-icon-box {
  animation: iconBounce 2s ease-in-out infinite;
}

@keyframes iconBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

.certificate-link-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.5rem;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  text-decoration: none;
  border-radius: 25px;
  font-size: 0.95rem;
  font-weight: 600;
  transition: all 0.3s;
  box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
}

.certificate-link-btn:hover {
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.5);
  background: linear-gradient(135deg, #764ba2, #667eea);
}

.certificate-link-btn svg {
  animation: linkPulse 2s ease-in-out infinite;
}

@keyframes linkPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

/* Achievements Section */
.achievements-section {
  padding: 5rem 2rem;
}

.achievements-section .grid {
  max-width: 1200px;
  margin: 0 auto;
}

/* Grid utility */
.grid {
  display: grid;
}

.md\:grid-cols-2 {
  grid-template-columns: repeat(2, 1fr);
}

.gap-8 {
  gap: 2rem;
}

/* Text utilities */
.text-xl {
  font-size: 1.25rem;
}

.font-bold {
  font-weight: 700;
}

.mb-2 {
  margin-bottom: 0.5rem;
}

.mb-3 {
  margin-bottom: 0.75rem;
}

.text-gray-600 {
  color: #4b5563;
}

.text-sm {
  font-size: 0.875rem;
}

.text-primary {
  color: #667eea;
}

.font-semibold {
  font-weight: 600;
}

.text-white {
  color: white;
}

.flex {
  display: flex;
}

.items-start {
  align-items: flex-start;
}

.gap-4 {
  gap: 1rem;
}

.flex-1 {
  flex: 1;
}

.p-3 {
  padding: 0.75rem;
}

.rounded-lg {
  border-radius: 0.5rem;
}

@media (max-width: 768px) {
  .md\:grid-cols-2 {
    grid-template-columns: 1fr;
  }
}
